# ============================================
# ArbiEdge Environment Configuration
# ============================================
# Copy this file: cp .env.example .env
# Then fill in your values

# ---------- Database (FREE: neon.tech) ----------
# Sign up free at neon.tech -> New Project -> Connection String
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
POSTGRES_USER=arbiedge
POSTGRES_PASSWORD=arbiedge_secret
POSTGRES_DB=arbiedge

# ---------- Redis (FREE: upstash.com) ----------
# Sign up free at upstash.com -> Redis -> Create DB -> Copy URL
REDIS_URL=redis://default:your_password@us1-xxx.upstash.io:6379

# ---------- JWT Authentication (NO CLERK NEEDED) ----------
# Generate secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------- Stripe (YOUR LIVE KEYS) ----------
# dashboard.stripe.com -> Developers -> API Keys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Create products at dashboard.stripe.com -> Products
STRIPE_STARTER_PRICE_ID=price_starter_id_here
STRIPE_PRO_PRICE_ID=price_pro_id_here
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id_here

# ---------- Amazon SP-API (Optional - for real deal scanning) ----------
# developer.amazon.com/sp-api
SP_API_CLIENT_ID=your_sp_api_client_id
SP_API_CLIENT_SECRET=your_sp_api_client_secret
SP_API_REFRESH_TOKEN=your_sp_api_refresh_token
SP_API_MARKETPLACE_ID=ATVPDKIKX0DER

# ---------- Amazon PA-API (Optional - for product data) ----------
# associates.amazon.com -> Tools -> PA-API
PA_API_ACCESS_KEY=your_pa_api_access_key
PA_API_SECRET_KEY=your_pa_api_secret_key
PA_API_PARTNER_TAG=your_partner_tag

# ---------- Backend URLs ----------
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Production: NEXT_PUBLIC_API_URL=https://arbiedge-backend.onrender.com/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://your-app.netlify.app"]

# ---------- App Environment ----------
ENVIRONMENT=development
DEBUG=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://your-app.netlify.app
